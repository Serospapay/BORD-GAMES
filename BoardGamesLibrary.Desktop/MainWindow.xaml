<Window x:Class="BoardGamesLibrary.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BoardGamesLibrary.Desktop"
        mc:Ignorable="d"
        Title="Бібліотека ігор з дошкою" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundGradient}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    <Window.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                           From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </Window.Triggers>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок з градієнтом -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryGradient}" 
                Padding="30"
                MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🎮 БІБЛІОТЕКА ІГОР" 
                              FontSize="36" 
                              FontWeight="Bold" 
                              Foreground="White"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="Класичні настільні ігри з сучасним дизайном" 
                              FontSize="16" 
                              Foreground="#E0E7FF"
                              Opacity="0.9"/>
                </StackPanel>
                <Button Grid.Column="1" 
                       x:Name="SoundToggleButton"
                       Content="🔊" 
                       Width="45" 
                       Height="45"
                       Background="Transparent"
                       Foreground="White"
                       BorderThickness="0"
                       FontSize="20"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Click="SoundToggleButton_Click"
                       Margin="0,0,10,0"
                       ToolTip="Вимкнути/Увімкнути звук">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" 
                       Content="✕" 
                       Width="45" 
                       Height="45"
                       Background="Transparent"
                       Foreground="White"
                       BorderThickness="0"
                       FontSize="24"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Click="CloseButton_Click"
                       Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EF4444"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        
        <!-- Контент -->
        <Grid Grid.Row="1" Margin="50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0" Margin="0,0,30,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" 
                      Text="Оберіть гру для початку" 
                      FontSize="28" 
                      FontWeight="SemiBold"
                      Foreground="{StaticResource TextPrimaryColor}"
                      Margin="0,0,0,40"
                      HorizontalAlignment="Center"/>
            
            <UniformGrid Grid.Row="1" 
                        Columns="2" 
                        Rows="2">
                <Button Content="♔ ШАХИ" 
                       Style="{StaticResource MenuButtonStyle}"
                       Click="ChessButton_Click"
                       Margin="20"/>
                <Button Content="● ШАШКИ" 
                       Style="{StaticResource MenuButtonStyle}"
                       Click="CheckersButton_Click"
                       Margin="20"/>
                <Button Content="◉ REVERSI" 
                       Style="{StaticResource MenuButtonStyle}"
                       Click="ReversiButton_Click"
                       Margin="20"/>
                <Button Content="⚫ CONNECT FOUR" 
                       Style="{StaticResource MenuButtonStyle}"
                       Click="ConnectFourButton_Click"
                       Margin="20"/>
            </UniformGrid>
            </Grid>
            
            <!-- Панель статистики -->
            <Border Grid.Column="1" 
                    Style="{StaticResource InfoPanelStyle}"
                    MinWidth="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0"
                              Text="СТАТИСТИКА"
                              FontSize="20"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryColor}"
                              Margin="0,0,0,20"
                              HorizontalAlignment="Center"/>
                    
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10">
                        <StackPanel x:Name="StatsPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
