<Window x:Class="BoardGamesLibrary.Desktop.ReversiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BoardGamesLibrary.Desktop"
        Title="Reversi/Othello" 
        Height="900" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundGradient}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryGradient}" 
                Padding="20"
                MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="◉ REVERSI/OTHELLO" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="1" 
                       Content="✕" 
                       Width="40" 
                       Height="40"
                       Background="Transparent"
                       Foreground="White"
                       BorderThickness="0"
                       FontSize="20"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EF4444"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        
        <!-- Ігрова дошка -->
        <Border Grid.Row="1" 
                Margin="30"
                Background="{StaticResource SurfaceColor}"
                CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>
            <local:ReversiBoardControl x:Name="ReversiBoard" 
                                       Margin="20"/>
        </Border>
        
        <!-- Інформація -->
        <Border Grid.Row="2" 
                Style="{StaticResource InfoPanelStyle}" 
                Margin="30,0,30,30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="CurrentPlayerText" 
                              FontSize="20" 
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryColor}"/>
                    <TextBlock x:Name="StatusText" 
                              FontSize="14" 
                              Foreground="{StaticResource TextSecondaryColor}"
                              Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📖 Правила" 
                           Style="{StaticResource MenuButtonStyle}"
                           Padding="20,12"
                           FontSize="16"
                           Margin="0,0,15,0"
                           Click="RulesButton_Click"/>
                    <Button Content="🔄 Нова гра" 
                           Style="{StaticResource MenuButtonStyle}"
                           Padding="25,12"
                           FontSize="16"
                           Click="NewGameButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
