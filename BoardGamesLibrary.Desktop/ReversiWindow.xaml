<Window x:Class="BoardGamesLibrary.Desktop.ReversiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BoardGamesLibrary.Desktop"
        Title="Reversi/Othello" 
        Height="900" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryGradient}" 
                Padding="20"
                MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="REVERSI / OTHELLO" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="1" 
                       Content="&#x2715;" 
                       Width="40" 
                       Height="40"
                       FontSize="20"
                       FontWeight="Bold"
                       Style="{StaticResource CloseButtonStyle}"
                       Click="CloseButton_Click"/>
            </Grid>
        </Border>
        
        <!-- Ігрова дошка -->
        <Border Grid.Row="1" Style="{StaticResource GameBoardHostStyle}">
            <local:ReversiBoardControl x:Name="ReversiBoard" Margin="20"/>
        </Border>
        
        <!-- Інформація -->
        <Border Grid.Row="2" 
                Style="{StaticResource InfoPanelStyle}" 
                Margin="30,0,30,30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="CurrentPlayerText" 
                              FontSize="20" 
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="StatusText" 
                              FontSize="14" 
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,4,0,0"/>
                    <StackPanel x:Name="LiveStatsPanel" Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Style="{StaticResource StatChipStyle}">
                            <TextBlock x:Name="MoveCountText" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                        <Border Style="{StaticResource StatChipStyle}">
                            <TextBlock x:Name="GameTimeText" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                        <Border Style="{StaticResource StatChipStyle}" Margin="0">
                            <TextBlock x:Name="PiecesText" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Правила" 
                           Style="{StaticResource PrimaryButtonStyle}"
                           Padding="20,12"
                           FontSize="15"
                           Margin="0,0,12,0"
                           Click="RulesButton_Click"/>
                    <Button Content="Нова гра" 
                           Style="{StaticResource PrimaryButtonStyle}"
                           Padding="24,12"
                           FontSize="15"
                           Click="NewGameButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
